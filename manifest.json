{
  "manifest_version": 3,
  "name": "PiraTrue Safety Net",
  "description": "Shows the safety status of piracy / repack sites based on PiraTrue and curated r/Piracy lists.",
  "version": "1.1.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "PiraTrue Safety Net"
  },
  "permissions": [
    "activeTab",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16-yellow.png",
    "32": "icons/icon32-yellow.png",
    "48": "icons/icon48-yellow.png",
    "128": "icons/icon128-yellow.png"
  }
}